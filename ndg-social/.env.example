# Anthropic API 키 (필수)
ANTHROPIC_API_KEY=sk-ant-...

# JWT 서명 비밀키 (랜덤 문자열, 32자 이상 권장)
SECRET_KEY=your-secret-key-change-this

# 데이터베이스 경로 (Railway 볼륨 마운트 시 /data/ndg_reports.db 로 변경)
DATABASE_URL=sqlite:////data/ndg_reports.db

# 초기 관리자 계정 (첫 배포 후 자동 생성에 사용)
INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PASSWORD=change-this-password
INIT_ADMIN_NAME=관리자

# AI 에이전트 목업 모드 (true: API 호출 없이 테스트, false: 실제 Claude 사용)
MOCK_AGENTS=false

# 디버그 모드
DEBUG=false
